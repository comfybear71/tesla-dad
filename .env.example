# ─── Price data (REQUIRED — app shows "no live price" until set, never fake data) ───
# Finnhub free tier: https://finnhub.io  (real-time US quotes)
FINNHUB_API_KEY=
# Alpha Vantage free tier: https://www.alphavantage.co/support/#api-key  (fallback)
ALPHAVANTAGE_API_KEY=

# ─── Telegram notifications ───
# 1. Message @BotFather in Telegram, send /newbot, copy the token below.
# 2. Start a chat with your new bot, send it any message.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and copy your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Persistence (optional) ───
# Add an Upstash Redis store in Vercel (Storage tab) and it injects these
# automatically. The app accepts EITHER naming scheme — legacy Vercel KV
# (KV_REST_API_*) or the Upstash marketplace integration (UPSTASH_REDIS_REST_*).
# Without them the app falls back to a local JSON file (fine for dev).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Cron security (optional) ───
# If set, /api/cron/check requires this as a Bearer token. Vercel Cron adds it
# automatically when you set CRON_SECRET in the project.
CRON_SECRET=
